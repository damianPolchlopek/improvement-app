# Szablon zmiennych środowiskowych backendu.
# Skopiuj ten plik do `.env` i uzupełnij wartościami.
# UWAGA: `.env` jest w .gitignore i NIE MOŻE trafić do repozytorium (zawiera sekrety).

# --- Google OAuth2 (logowanie przez Google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Poczta SMTP (weryfikacja e-mail, powiadomienia) ---
MAIL_USERNAME=
MAIL_PASSWORD=

# --- JWT ---
# Sekret do podpisywania tokenów (zalecane: losowy ciąg Base64, min. 256 bitów)
JWT_SECRET=

# --- Integracje zewnętrzne ---
COINMARKETCAP_API_KEY=

# --- PostgreSQL ---
DB_USERNAME=
DB_PASSWORD=
DB_URL=

# --- MongoDB ---
MONGODB_URI=

# --- Produkcja (HTTPS, profil smallhost) ---
# SSL_KEYSTORE_PASSWORD=

# --- Docker (opcjonalnie, dla Testcontainers na Windows) ---
# DOCKER_HOST=tcp://localhost:2375
