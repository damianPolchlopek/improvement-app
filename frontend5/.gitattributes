# Auto detect text files and perform LF normalization
* text=auto eol=crlf

# Source files
*.js    text eol=crlf
*.jsx   text eol=crlf
*.ts    text eol=crlf
*.tsx   text eol=crlf
*.css   text eol=crlf
*.html  text eol=crlf
*.json  text eol=crlf
*.md    text eol=crlf

# Binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
